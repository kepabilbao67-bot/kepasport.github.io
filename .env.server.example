# Variables de entorno del servidor (CRM de Clientes con Asistente Claude)
#
# Copia este archivo a ".env.server" y completa los valores reales.
# El archivo ".env.server" NO debe subirse al control de versiones (ver .gitignore).
# Wasp carga automaticamente las variables definidas en ".env.server" en el backend.

# Clave de API de Anthropic. Obligatoria: si falta, el asistente devuelve un error de configuracion.
# (Requisitos 8.3, 8.5)
ANTHROPIC_API_KEY=

# Identificador del modelo de Claude a utilizar.
# Si se deja vacia, el sistema usa por defecto "claude-3-5-sonnet". (Requisitos 8.1, 8.2)
CLAUDE_MODEL=

# URL del webhook de salida de Zapier. Opcional: si se deja vacia, se omite la notificacion.
# Se conserva por compatibilidad hacia atras; tambien se incluye en la lista de destinos.
# (Requisitos 10.2, 10.3)
ZAPIER_WEBHOOK_URL=

# Lista de destinos de salida para la automatizacion GENERICA. Opcional.
# Permite notificar a CUALQUIER sistema externo (Make, n8n, un endpoint HTTP propio,
# otra cuenta de Zapier, etc.), no solo a Zapier. Indica una o varias URLs de webhook
# separadas por comas (y/o espacios). Cada destino recibe un POST con { event, client }.
# Si se deja vacia y ZAPIER_WEBHOOK_URL tampoco esta configurada, se omite la notificacion.
# Ejemplo: OUTBOUND_WEBHOOK_URLS=https://hook.make.com/abc,https://n8n.midominio.com/webhook/xyz
# (Requisitos 10.1, 10.3, 10.4)
OUTBOUND_WEBHOOK_URLS=

# Token del endpoint de entrada de Zapier. Si falta, se rechazan todas las solicitudes entrantes.
# (Requisito 11.4)
ZAPIER_INBOUND_TOKEN=
